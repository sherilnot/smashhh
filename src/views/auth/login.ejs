<!DOCTYPE html>
<!--
  Login view — Burger Store themed.
  Requirement 18.1: dynamic content rendered with EJS auto-escaping (<%= %>).
  Locals: error {string|null}, userId {string}
-->
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login - Burger Store</title>
  <link rel="stylesheet" href="/css/theme.css" />
</head>
<body>
  <div class="login-wrap">
    <div class="login-card">
      <div class="brand-big">🍔 Burger Store</div>
      <div class="tagline">Staff &amp; Shift Management</div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="error"><%= error %></div>
      <% } %>

      <form method="POST" action="/login">
        <div class="form-group">
          <label for="user_id">User ID</label>
          <input type="text" id="user_id" name="user_id"
            value="<%= typeof userId !== 'undefined' && userId ? userId : '' %>"
            autocomplete="username" required />
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password"
            autocomplete="current-password" required />
        </div>
        <button type="submit" class="btn">Log In</button>
      </form>
    </div>
  </div>
</body>
</html>
