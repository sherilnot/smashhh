<%- include('../partials/header', { title: 'Dashboard - Burger Store', role: 'employee', active: 'dashboard' }) %>

  <h1><span class="emoji">🍔</span>Crew Dashboard</h1>
  <div class="card">
    <p>Welcome! Grab open shifts, track your bookings, and watch your earnings stack up.</p>
  </div>

  <h2>My Wages</h2>
  <% var entries = (typeof wageEntries !== 'undefined' && wageEntries) ? wageEntries : []; %>
  <% if (entries.length === 0) { %>
    <p class="empty">No wage entries are available yet.</p>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Shift date</th>
          <th>Worked hours</th>
          <th class="amount">Amount</th>
        </tr>
      </thead>
      <tbody>
        <% entries.forEach(entry => { %>
          <tr>
            <td><%= new Date(entry.date).toLocaleDateString() %></td>
            <td><%= entry.hoursWorked %></td>
            <td class="amount">$<%= Number(entry.wageEarned).toFixed(2) %></td>
          </tr>
        <% }) %>
      </tbody>
      <tfoot>
        <tr>
          <td colspan="2">Total</td>
          <td class="amount">$<%= Number(typeof wageTotal !== 'undefined' ? wageTotal : 0).toFixed(2) %></td>
        </tr>
      </tfoot>
    </table>
  <% } %>

<%- include('../partials/footer') %>
