<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Employee Dashboard</title>
  <style>
    body { font-family: Arial, sans-serif; max-width: 800px; margin: 2rem auto; padding: 0 1rem; }
    nav a { margin-right: 1rem; }
    .card { background: #f4f5f7; padding: 1.5rem; border-radius: 8px; margin-top: 1rem; }
  </style>
</head>
<body>
  <h1>Employee Dashboard</h1>
  <nav>
    <a href="/employee/shifts">Available Shifts</a>
    <a href="/employee/my-shifts">My Shifts</a>
    <form style="display:inline" method="POST" action="/logout">
      <button type="submit">Logout</button>
    </form>
  </nav>
  <div class="card">
    <p>Welcome! Use the links above to view and book available shifts.</p>
  </div>
</body>
</html>
