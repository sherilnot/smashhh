<%- include('../partials/header', { title: 'My Shifts - Burger Store', role: 'employee', active: 'my-shifts' }) %>

  <h1><span class="emoji">🧾</span>My Shifts</h1>

  <% if (error) { %><div class="error"><%= error %></div><% } %>

  <% if (shifts.length === 0) { %>
    <p class="empty">No shifts found in this period.</p>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Date</th>
          <th>Start</th>
          <th>End</th>
          <th>Location</th>
          <th>Status</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% shifts.forEach(shift => { %>
          <% const status = (shift.bookingStatus === null || shift.bookingStatus === undefined || shift.bookingStatus === '') ? null : String(shift.bookingStatus); %>
          <tr>
            <td><%= new Date(shift.startTime).toLocaleDateString() %></td>
            <td><%= new Date(shift.startTime).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}) %></td>
            <td><%= new Date(shift.endTime).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}) %></td>
            <td><%= shift.storeLocation %></td>
            <td class="status-<%= status === null ? 'unknown' : status %>"><%= status === null ? 'Unknown' : status %></td>
            <td>
              <% if (status === 'confirmed') { %>
                <form method="POST" action="/employee/cancel">
                  <input type="hidden" name="shiftId" value="<%= shift.id %>" />
                  <button type="submit" class="cancel-btn">Cancel</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>

<%- include('../partials/footer') %>
