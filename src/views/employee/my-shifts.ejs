<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>My Shifts</title>
  <style>
    body { font-family: Arial, sans-serif; max-width: 900px; margin: 2rem auto; padding: 0 1rem; }
    nav a { margin-right: 1rem; }
    table { width: 100%; border-collapse: collapse; margin-top: 1rem; }
    th, td { padding: 0.6rem 0.8rem; border: 1px solid #ddd; text-align: left; }
    th { background: #f4f5f7; }
    .error { background: #fee2e2; color: #b91c1c; padding: 0.5rem 0.75rem; border-radius: 4px; margin-bottom: 1rem; }
    .status-confirmed { color: #15803d; font-weight: bold; }
    .status-cancelled { color: #b91c1c; }
    .status-completed { color: #1d4ed8; }
    button.cancel-btn { background: #dc2626; color: #fff; border: none; padding: 0.4rem 0.8rem; border-radius: 4px; cursor: pointer; }
  </style>
</head>
<body>
  <h1>My Shifts</h1>
  <nav>
    <a href="/employee/dashboard">Dashboard</a>
    <a href="/employee/shifts">Available Shifts</a>
    <form style="display:inline" method="POST" action="/logout">
      <button type="submit">Logout</button>
    </form>
  </nav>

  <% if (error) { %><div class="error"><%= error %></div><% } %>

  <% if (shifts.length === 0) { %>
    <p>No shifts found in this period.</p>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Date</th>
          <th>Start</th>
          <th>End</th>
          <th>Location</th>
          <th>Status</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% shifts.forEach(shift => { %>
          <tr>
            <td><%= new Date(shift.startTime).toLocaleDateString() %></td>
            <td><%= new Date(shift.startTime).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}) %></td>
            <td><%= new Date(shift.endTime).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}) %></td>
            <td><%= shift.storeLocation %></td>
            <td class="status-<%= shift.bookingStatus %>"><%= shift.bookingStatus %></td>
            <td>
              <% if (shift.bookingStatus === 'confirmed') { %>
                <form method="POST" action="/employee/cancel">
                  <input type="hidden" name="shiftId" value="<%= shift.id %>" />
                  <button type="submit" class="cancel-btn">Cancel</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</body>
</html>
