<%- include('../partials/header', { title: 'Available Shifts - Burger Store', role: 'employee', active: 'shifts' }) %>

  <h1><span class="emoji">🗓️</span>Available Shifts</h1>

  <% if (error) { %><div class="error"><%= error %></div><% } %>

  <% if (shifts.length === 0) { %>
    <p class="empty">No available shifts in this period.</p>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Date</th>
          <th>Start</th>
          <th>End</th>
          <th>Location</th>
          <th>Spots Left</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% shifts.forEach(shift => { %>
          <tr>
            <td><%= new Date(shift.startTime).toLocaleDateString() %></td>
            <td><%= new Date(shift.startTime).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}) %></td>
            <td><%= new Date(shift.endTime).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}) %></td>
            <td><%= shift.storeLocation %></td>
            <td><%= shift.capacity - shift.currentBookings %></td>
            <td>
              <form method="POST" action="/employee/book">
                <input type="hidden" name="shiftId" value="<%= shift.id %>" />
                <button type="submit">Book</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>

<%- include('../partials/footer') %>
