<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Store Manager Dashboard</title>
  <style>
    body { font-family: Arial, sans-serif; max-width: 800px; margin: 2rem auto; padding: 0 1rem; }
    nav a { margin-right: 1rem; }
    .card { background: #f4f5f7; padding: 1.5rem; border-radius: 8px; margin-top: 1rem; }
    button { background: none; border: none; color: #2563eb; cursor: pointer; text-decoration: underline; }
  </style>
</head>
<body>
  <h1>Store Manager Dashboard</h1>
  <nav>
    <a href="/manager/wages">Wage Reports</a>
    <a href="/manager/employees">Employees</a>
    <form style="display:inline" method="POST" action="/logout">
      <button type="submit">Logout</button>
    </form>
  </nav>
  <div class="card">
    <p>Welcome! Use the links above to view wage reports and manage employee hourly rates.</p>
  </div>
</body>
</html>
