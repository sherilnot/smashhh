<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Employees</title>
  <style>
    body { font-family: Arial, sans-serif; max-width: 800px; margin: 2rem auto; padding: 0 1rem; }
    nav a { margin-right: 1rem; }
    table { width: 100%; border-collapse: collapse; margin-top: 1rem; }
    th, td { padding: 0.6rem 0.8rem; border: 1px solid #ddd; text-align: left; }
    th { background: #f4f5f7; }
    .error { background: #fee2e2; color: #b91c1c; padding: 0.5rem 0.75rem; border-radius: 4px; margin-bottom: 1rem; }
    .msg { background: #dcfce7; color: #15803d; padding: 0.5rem 0.75rem; border-radius: 4px; margin-bottom: 1rem; }
    input[type=number] { width: 80px; padding: 0.3rem; border: 1px solid #ccc; border-radius: 4px; }
    button { background: #2563eb; color: #fff; border: none; padding: 0.3rem 0.7rem; border-radius: 4px; cursor: pointer; }
    nav button { background: none; color: #2563eb; text-decoration: underline; padding: 0; }
  </style>
</head>
<body>
  <h1>Employees</h1>
  <nav>
    <a href="/manager/dashboard">Dashboard</a>
    <a href="/manager/wages">Wages</a>
    <form style="display:inline" method="POST" action="/logout">
      <button type="submit">Logout</button>
    </form>
  </nav>

  <% if (error) { %><div class="error"><%= error %></div><% } %>
  <div id="msg"></div>

  <table>
    <thead>
      <tr><th>User ID</th><th>Name</th><th>Hourly Rate</th><th>Update Rate</th></tr>
    </thead>
    <tbody>
      <% employees.forEach(emp => { %>
      <tr>
        <td><%= emp.user_id %></td>
        <td><%= emp.first_name %> <%= emp.last_name %></td>
        <td>$<%= parseFloat(emp.hourly_wage).toFixed(2) %></td>
        <td>
          <form onsubmit="updateRate(event, '<%= emp.id %>', this)">
            <input type="number" name="rate" step="0.01" min="0.01" value="<%= parseFloat(emp.hourly_wage).toFixed(2) %>" required />
            <button type="submit">Save</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>

  <script>
    async function updateRate(e, employeeId, form) {
      e.preventDefault();
      const rate = form.querySelector('input[name=rate]').value;
      const res = await fetch('/manager/update-rate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ employeeId, newRate: parseFloat(rate) })
      });
      const data = await res.json();
      const msg = document.getElementById('msg');
      if (data.success) {
        msg.className = 'msg';
        msg.textContent = 'Rate updated successfully.';
      } else {
        msg.className = 'error';
        msg.textContent = data.error || 'Update failed.';
      }
    }
  </script>
</body>
</html>
