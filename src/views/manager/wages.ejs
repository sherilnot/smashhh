<%- include('../partials/header', { title: 'Wage Reports - Burger Store', role: 'store_manager', active: 'wages' }) %>

  <h1><span class="emoji">💵</span>Wage Reports</h1>

  <% if (error) { %><div class="error"><%= error %></div><% } %>

  <form class="filter" method="GET" action="/manager/wages">
    <label>From: <input type="date" name="start" value="<%= filters.start || '' %>" /></label>
    <label>To: <input type="date" name="end" value="<%= filters.end || '' %>" /></label>
    <button type="submit">Filter</button>
  </form>

  <% if (summary) { %>
  <div class="summary">
    <div><strong><%= summary.totalEmployees %></strong> Employees</div>
    <div><strong><%= summary.totalHours %></strong> Total Hours</div>
    <div><strong>$<%= summary.totalWages %></strong> Total Wages</div>
    <div><span><%= summary.periodStart %> → <%= summary.periodEnd %></span></div>
  </div>
  <% } %>

  <% if (reports.length === 0) { %>
    <p class="empty">No completed shifts in this period.</p>
  <% } else { %>
    <table>
      <thead>
        <tr><th>Employee</th><th>Hours</th><th>Rate ($/hr)</th><th>Total Wages</th><th>Breakdown</th></tr>
      </thead>
      <tbody>
        <% reports.forEach(r => { %>
        <tr>
          <td><%= r.employeeName %></td>
          <td><%= r.totalHours %></td>
          <td>$<%= r.hourlyRate.toFixed(2) %></td>
          <td>$<%= r.totalWages.toFixed(2) %></td>
          <td>
            <details>
              <summary><%= r.shiftBreakdown.length %> shift(s)</summary>
              <table class="breakdown-table">
                <tr><th>Date</th><th>Hours</th><th>Wage</th></tr>
                <% r.shiftBreakdown.forEach(s => { %>
                <tr>
                  <td><%= new Date(s.date).toLocaleDateString() %></td>
                  <td><%= s.hoursWorked %></td>
                  <td>$<%= s.wageEarned.toFixed(2) %></td>
                </tr>
                <% }) %>
              </table>
            </details>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>

<%- include('../partials/footer') %>
