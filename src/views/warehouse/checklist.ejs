<%- include('../partials/header', { title: 'Inventory Checklist - Burger Store', role: 'warehouse_manager', active: 'checklist' }) %>

  <h1><span class="emoji">📦</span>Inventory Checklist</h1>

  <form class="date-form" method="GET" action="/warehouse/checklist">
    <label>Date: <input type="date" name="date" value="<%= date.toISOString().split('T')[0] %>" /></label>
    <button type="submit">Load</button>
  </form>

  <% if (error) { %><div class="error"><%= error %></div><% } %>

  <p>Status: <span class="badge"><%= checklist.status %></span></p>

  <table>
    <thead>
      <tr><th>Product</th><th>Expected</th><th>Actual</th><th>Status</th><th>Action</th></tr>
    </thead>
    <tbody>
      <% checklist.items.forEach(item => { %>
      <tr id="row-<%= item.id %>">
        <td><%= item.product_name %></td>
        <td><%= item.expected_quantity %></td>
        <td><%= item.actual_quantity !== null ? item.actual_quantity : '—' %></td>
        <td class="status-<%= item.status %>"><%= item.status %></td>
        <td>
          <% if (item.status === 'pending') { %>
          <form style="display:flex;gap:0.4rem" onsubmit="checkItem(event,'<%= item.id %>','<%= checklist.id %>')">
            <input type="number" name="qty" min="0" max="<%= item.expected_quantity %>" placeholder="Qty" required />
            <button type="submit" class="check-btn">Submit</button>
          </form>
          <% } else { %>
          <span style="color:#8a7765;font-size:0.875rem">Checked <%= item.checked_at ? new Date(item.checked_at).toLocaleTimeString() : '' %></span>
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>

  <script>
    async function checkItem(e, itemId, checklistId) {
      e.preventDefault();
      const qty = parseInt(e.target.querySelector('input[name=qty]').value);
      const res = await fetch('/warehouse/check-item', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ checklistId, itemId, actualQuantity: qty })
      });
      const data = await res.json();
      if (data.success) location.reload();
      else alert(data.error || 'Failed to update item');
    }
  </script>

<%- include('../partials/footer') %>
