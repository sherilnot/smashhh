<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Checklist History</title>
  <style>
    body { font-family: Arial, sans-serif; max-width: 900px; margin: 2rem auto; padding: 0 1rem; }
    nav a { margin-right: 1rem; }
    nav button { background: none; border: none; color: #2563eb; cursor: pointer; text-decoration: underline; }
    .error { background: #fee2e2; color: #b91c1c; padding: 0.5rem 0.75rem; border-radius: 4px; margin-bottom: 1rem; }
    table { width: 100%; border-collapse: collapse; margin-top: 1rem; }
    th, td { padding: 0.6rem 0.8rem; border: 1px solid #ddd; text-align: left; }
    th { background: #f4f5f7; }
    .status-pending { color: #92400e; }
    .status-in_progress { color: #1d4ed8; }
    .status-completed { color: #15803d; }
    a.view-link { color: #2563eb; }
  </style>
</head>
<body>
  <h1>Checklist History</h1>
  <nav>
    <a href="/warehouse/dashboard">Dashboard</a>
    <a href="/warehouse/checklist">Today's Checklist</a>
    <form style="display:inline" method="POST" action="/logout">
      <button type="submit">Logout</button>
    </form>
  </nav>

  <% if (error) { %><div class="error"><%= error %></div><% } %>

  <% if (history.length === 0) { %>
    <p>No checklist history in the last 30 days.</p>
  <% } else { %>
    <table>
      <thead>
        <tr><th>Date</th><th>Status</th><th>Items</th><th>Checked</th><th>Action</th></tr>
      </thead>
      <tbody>
        <% history.forEach(h => { %>
        <tr>
          <td><%= new Date(h.check_date).toLocaleDateString() %></td>
          <td class="status-<%= h.status %>"><%= h.status %></td>
          <td><%= h.total_items %></td>
          <td><%= h.checked_items %> / <%= h.total_items %></td>
          <td>
            <a class="view-link" href="/warehouse/checklist?date=<%= new Date(h.check_date).toISOString().split('T')[0] %>">View</a>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</body>
</html>
