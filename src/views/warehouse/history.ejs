<%- include('../partials/header', { title: 'Checklist History - Burger Store', role: 'warehouse_manager', active: 'history' }) %>

  <h1><span class="emoji">📚</span>Checklist History</h1>

  <% if (error) { %><div class="error"><%= error %></div><% } %>

  <% if (history.length === 0) { %>
    <p class="empty">No checklist history in the last 30 days.</p>
  <% } else { %>
    <table>
      <thead>
        <tr><th>Date</th><th>Status</th><th>Items</th><th>Checked</th><th>Action</th></tr>
      </thead>
      <tbody>
        <% history.forEach(h => { %>
        <tr>
          <td><%= new Date(h.check_date).toLocaleDateString() %></td>
          <td class="status-<%= h.status %>"><%= h.status %></td>
          <td><%= h.total_items %></td>
          <td><%= h.checked_items %> / <%= h.total_items %></td>
          <td>
            <a class="btn" href="/warehouse/checklist?date=<%= new Date(h.check_date).toISOString().split('T')[0] %>" style="text-decoration:none;display:inline-block;">View</a>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>

<%- include('../partials/footer') %>
